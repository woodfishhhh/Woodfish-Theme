{
  "name": "woodfish-theme",
  "displayName": "Woodfish Theme",
  "description": "🌈 Woodfish 彩虹主题 - 回档到稳定版本，具有发光效果、渐变色彩和动画的VSCode主题扩展",
  "version": "5.0.2",
  "publisher": "zhongjun",
  "author": {
    "name": "Woodfish"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "keywords": [
    "theme",
    "woodfish",
    "dark",
    "rainbow",
    "gradient",
    "glow",
    "animation",
    "cursor",
    "ui",
    "custom",
    "colorful",
    "neon",
    "cyberpunk"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:woodfish-theme.enable",
    "onCommand:woodfish-theme.disable",
    "onCommand:woodfish-theme.toggleSyntaxGradient",
    "onCommand:woodfish-theme.toggleGlow",
    "onCommand:woodfish-theme.autoConfigureRainbowCursor",
    "onCommand:woodfish-theme.toggleRainbowCursor",
    "onCommand:woodfish-theme.repairWorkbench",
    "onCommand:woodfish-theme.completeUninstall"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "themes": [
      {
        "label": "Woodfish Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/Bearded Theme/Bearded Theme.json"
      }
    ],
    "commands": [
      {
        "command": "woodfish-theme.enable",
        "title": "开启 Woodfish 主题",
        "category": "Woodfish Theme"
      },
      {
        "command": "woodfish-theme.disable",
        "title": "关闭 Woodfish 主题",
        "category": "Woodfish Theme"
      },
      {
        "command": "woodfish-theme.toggleSyntaxGradient",
        "title": "开启/关闭 Woodfish 彩色字体",
        "category": "Woodfish Theme"
      },
      {
        "command": "woodfish-theme.toggleGlow",
        "title": "开启/关闭 Woodfish 发光字体",
        "category": "Woodfish Theme"
      },
      {
        "command": "woodfish-theme.autoConfigureRainbowCursor",
        "title": "开启 Woodfish 彩色光标",
        "category": "Woodfish Theme"
      },
      {
        "command": "woodfish-theme.toggleRainbowCursor",
        "title": "开启/关闭彩色光标",
        "category": "Woodfish Theme"
      },
      {
        "command": "woodfish-theme.repairWorkbench",
        "title": "修复 Woodfish 注入",
        "category": "Woodfish Theme"
      },
      {
        "command": "woodfish-theme.completeUninstall",
        "title": "彻底停用 Woodfish 主题",
        "category": "Woodfish Theme"
      }
    ],
    "configuration": {
      "title": "Woodfish Theme",
      "properties": {
        "woodfishTheme.runtime.enabled": {
          "type": "boolean",
          "default": true,
          "description": "启用 Woodfish 一体化运行时注入。"
        },
        "woodfishTheme.runtime.autoSwitchTheme": {
          "type": "boolean",
          "default": true,
          "description": "启用 Woodfish 时自动切换到 Woodfish Dark。"
        },
        "woodfishTheme.runtime.reapplyOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "启动 VS Code 时自动检查并重应用 Woodfish 注入。"
        },
        "woodfishTheme.syntaxGradient.enabled": {
          "type": "boolean",
          "default": true,
          "description": "启用彩色字体层。"
        },
        "woodfishTheme.syntaxGradient.preset": {
          "type": "string",
          "default": "woodfish",
          "enum": [
            "woodfish"
          ],
          "description": "彩色字体预设。"
        },
        "woodfishTheme.syntaxGradient.customRules": {
          "type": "array",
          "default": [],
          "description": "追加到彩色字体层后的自定义 CSS 规则。",
          "items": {
            "type": "string"
          }
        },
        "woodfishTheme.glow.enabled": {
          "type": "boolean",
          "default": true,
          "description": "启用发光字体层。"
        },
        "woodfishTheme.glow.intensity": {
          "type": "number",
          "default": 1,
          "minimum": 0.1,
          "maximum": 3,
          "description": "发光强度倍率。1 为默认强度。"
        },
        "woodfishTheme.glow.customRules": {
          "type": "array",
          "default": [],
          "description": "追加到发光层后的自定义 CSS 规则。",
          "items": {
            "type": "string"
          }
        },
        "woodfishTheme.cursor.enabled": {
          "type": "boolean",
          "default": true,
          "description": "启用彩色光标层。"
        },
        "woodfishTheme.cursor.animationDuration": {
          "type": "number",
          "default": 8,
          "minimum": 1,
          "maximum": 60,
          "description": "彩色光标动画时长，单位为秒。"
        },
        "woodfishTheme.cursor.gradientStops": {
          "type": "array",
          "default": [
            "#ff2d95",
            "#ff4500",
            "#ffd700",
            "#7cfc00",
            "#00ffff",
            "#1e90ff",
            "#9370db",
            "#ff00ff",
            "#ff1493"
          ],
          "description": "彩色光标渐变颜色列表。",
          "items": {
            "type": "string"
          }
        },
        "woodfishTheme.cursor.borderRadius": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "maximum": 24,
          "description": "彩色光标圆角半径。"
        },
        "woodfishTheme.cursor.glow": {
          "type": "boolean",
          "default": true,
          "description": "启用光标尾迹发光。"
        },
        "woodfishTheme.cursor.glowBlur": {
          "type": "number",
          "default": 4,
          "minimum": 0,
          "maximum": 24,
          "description": "彩色光标发光模糊半径。"
        },
        "woodfishTheme.cursor.glowOpacity": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 1,
          "description": "彩色光标发光透明度。"
        },
        "woodfishTheme.cursor.customRules": {
          "type": "array",
          "default": [],
          "description": "追加到彩色光标层后的自定义 CSS 规则。",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "vscode:prepublish": "npm run compile",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "pre-publish": "node scripts/pre-publish-check.js",
    "publish": "node scripts/publish.js",
    "publish:pre-release": "node scripts/publish.js --pre-release",
    "package": "vsce package",
    "clean": "rimraf *.vsix"
  },
  "devDependencies": {
    "@types/node": "^16.18.126",
    "@types/vscode": "^1.74.0",
    "@vscode/test-electron": "^2.2.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@types/jest": "^29.5.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "globals": "^16.5.0",
    "jest": "^29.7.0",
    "prettier": "^3.7.4",
    "ts-jest": "^29.2.0",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/woodfish/woodfish-theme.git"
  },
  "bugs": {
    "url": "https://github.com/woodfish/woodfish-theme/issues"
  },
  "homepage": "https://github.com/woodfish/woodfish-theme#readme",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "icon": "images/head.jpg"
}
